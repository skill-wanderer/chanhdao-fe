# Public site URL (used for SSR redirect URIs behind reverse proxy)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Keycloak Authentication (optional — leave blank to disable login/register UI)
NUXT_PUBLIC_KEYCLOAK_URL=https://sso.chandao.vn
NUXT_PUBLIC_KEYCLOAK_REALM=chanhdao
NUXT_PUBLIC_KEYCLOAK_CLIENT_ID=lms

# Backend API base URL (for lesson completion, progress tracking, etc.)
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Lyra Chatbot (AnLacVien API)
NUXT_PUBLIC_ANLACVIEN_API_URL=http://localhost:8000
NUXT_PUBLIC_ANLACVIEN_DOMAINS=chanhdao.com
NUXT_PUBLIC_ANLACVIEN_SESSION_EXPIRY_MINUTES=30
NUXT_PUBLIC_ANLACVIEN_SESSION_STORAGE=browser
